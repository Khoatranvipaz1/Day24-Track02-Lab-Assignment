#!/bin/bash
# Pre-commit hook: chạy security checks trước khi commit.
# Portable: dùng git-secrets nếu có, nếu không fallback sang scripts/secret_scan.py
# (không cần binary ngoài — chạy được trên Windows/Git Bash).

set -u
echo "🔍 Running security checks..."

PY="${PYTHON:-python}"

# 1. Secret scan
if command -v git-secrets >/dev/null 2>&1; then
    echo "🔑 git-secrets..."
    git secrets --pre_commit_hook -- "$@" || {
        echo "❌ git-secrets found potential secrets! Commit blocked."; exit 1; }
else
    echo "🔑 secret_scan.py (fallback)..."
    "$PY" scripts/secret_scan.py || {
        echo "❌ secret_scan found potential secrets! Commit blocked."; exit 1; }
fi

# 2. Bandit SAST scan
echo "🐍 Running Bandit SAST..."
"$PY" -m bandit -r src/ -ll -q || {
    echo "❌ Bandit found security issues! Review above."; exit 1; }

# 3. pip-audit dependency check (chỉ cảnh báo, không chặn — vì cryptography bị
#    presidio ghim <47 nên còn 1 CVE không thể vá; xem reports/SECURITY_AUDIT.md)
echo "📦 Checking dependencies for CVEs..."
"$PY" -m pip_audit || echo "⚠️  Có CVE phụ thuộc — xem reports/SECURITY_AUDIT.md"

echo "✅ All security checks passed!"
exit 0
